{
  "expo": {
    "name": "LiteroQuest",
    "slug": "literoquest",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFF9F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.literoquest.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF9F0"
      },
      "package": "com.literoquest.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-sqlite",
      "expo-localization",
      "expo-audio"
    ],
    "newArchEnabled": false,
    "extra": {
      "eas": {
        "projectId": "9c5ff320-3ddd-4c61-aa7b-a5c921797a3a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9c5ff320-3ddd-4c61-aa7b-a5c921797a3a"
    }
  }
}
